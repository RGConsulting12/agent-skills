{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "run_state.schema.json",
  "title": "Phase1RunState",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "plan_id",
    "status",
    "created_at",
    "tasks",
    "artifacts"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "run_id": {
      "type": "string"
    },
    "plan_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "initialized",
        "running",
        "completed",
        "failed",
        "cancelled"
      ]
    },
    "created_at": {
      "type": "string"
    },
    "started_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "ended_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "tasks": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "task_id",
          "status",
          "attempts",
          "max_retries",
          "approval",
          "depends_on",
          "produced_artifacts"
        ],
        "properties": {
          "task_id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending_approval",
              "blocked",
              "ready",
              "running",
              "completed",
              "failed",
              "cancelled"
            ]
          },
          "attempts": {
            "type": "integer",
            "minimum": 0
          },
          "max_retries": {
            "type": "integer",
            "minimum": 0
          },
          "last_error": {
            "type": [
              "object",
              "null"
            ]
          },
          "approval": {
            "type": "object",
            "required": [
              "required",
              "approved"
            ],
            "properties": {
              "required": {
                "type": "boolean"
              },
              "approved": {
                "type": "boolean"
              },
              "approved_by": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "approved_at": {
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "additionalProperties": false
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "started_at": {
            "type": [
              "string",
              "null"
            ]
          },
          "ended_at": {
            "type": [
              "string",
              "null"
            ]
          },
          "produced_artifacts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "current_task_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "summary": {
      "type": "object"
    },
    "metadata": {
      "type": "object"
    }
  },
  "additionalProperties": false
}

