{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "plan.schema.json",
  "title": "Phase1Plan",
  "type": "object",
  "required": [
    "schema_version",
    "plan_id",
    "title",
    "created_at",
    "created_by",
    "tasks"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "plan_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "type": "string",
      "minLength": 1
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "task.schema.json"
      }
    },
    "metadata": {
      "type": "object"
    }
  },
  "additionalProperties": false
}

