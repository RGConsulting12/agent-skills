{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "artifact.schema.json",
  "title": "Phase1Artifact",
  "type": "object",
  "required": [
    "artifact_id",
    "run_id",
    "producer_task_id",
    "type",
    "status",
    "created_at"
  ],
  "properties": {
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "producer_task_id": {
      "type": "string",
      "minLength": 1
    },
    "producer_delegation_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "producer_child_run_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "lineage_depth": {
      "type": "integer",
      "minimum": 0
    },
    "type": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "final"
      ]
    },
    "path": {
      "type": [
        "string",
        "null"
      ]
    },
    "content": {},
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object"
    }
  },
  "additionalProperties": false
}

