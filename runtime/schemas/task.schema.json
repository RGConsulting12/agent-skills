{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "task.schema.json",
  "title": "Phase1Task",
  "type": "object",
  "required": [
    "task_id",
    "title",
    "execution"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "depends_on": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "priority": {
      "type": "integer"
    },
    "approval_required": {
      "type": "boolean"
    },
    "execution": {
      "type": "object",
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "noop",
            "shell"
          ]
        },
        "command": {
          "type": "string"
        },
        "cwd": {
          "type": "string"
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "emit_artifact": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "retry_policy": {
      "type": "object",
      "properties": {
        "max_retries": {
          "type": "integer",
          "minimum": 0
        },
        "backoff_base_seconds": {
          "type": "integer",
          "minimum": 0
        },
        "backoff_factor": {
          "type": "number",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "expected_artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "metadata": {
      "type": "object"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "execution": {
            "properties": {
              "kind": {
                "const": "shell"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "execution": {
            "required": [
              "kind",
              "command"
            ]
          }
        }
      }
    }
  ],
  "additionalProperties": false
}

